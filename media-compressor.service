[Unit]
Description=Media Compressor Job
After=network.target

[Service]
Type=oneshots
ExecStart=/usr/bin/python3 /home/devuser/media/utility/converter/main.py amd /home/devuser/media/
User=devuser
CPUAccounting=true
CPUQuota=10%
MemoryHigh=900M
MemoryMax=1G
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7